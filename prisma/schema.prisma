// Reach — Prisma schema
// Phase 1 minimum: Profile + AuditEvent. More models land in Phase 2-3.
// See CLAUDE.md architectural rules and docs/rbac-matrix.md.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// Connection URLs live in prisma.config.ts (Prisma 7 pattern).
// Runtime queries use the DATABASE_URL via adapter passed to PrismaClient.
// Prisma CLI (migrations) uses DIRECT_URL via prisma.config.ts datasource.url.

// -----------------------------------------------------------------
// Roles — aligns with docs/rbac-matrix.md §Role codes.
// -----------------------------------------------------------------
enum Role {
  EXECUTIVE
  OPS_ADMIN
  PM
  DESIGN_ENGINEER
  ESTIMATOR
  PROGRAMMER
  WAREHOUSE
  TECH_LEAD
  TECH_USER
  FINANCE
  SALES
  SERVICE
}

// -----------------------------------------------------------------
// Profile — app-level user record.
// id matches Supabase auth.users.id (no FK declared; auth schema is
// managed by Supabase, not Prisma). A profile row is upserted on
// first authenticated request.
// -----------------------------------------------------------------
model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

// -----------------------------------------------------------------
// AuditEvent — CLAUDE.md rule 8: audit log is not optional.
// Append-only. Indexed for actor-, type-, and resource-based queries.
// -----------------------------------------------------------------
enum AuditEventType {
  // Auth
  SIGN_IN
  SIGN_OUT
  SIGN_IN_FAILED
  MFA_ENROLL
  MFA_CHALLENGE_PASS
  MFA_CHALLENGE_FAIL

  // Authorization
  AUTHZ_DENIED

  // Trusted-core (stubs — more added as modules land)
  PERMISSION_GRANT_CHANGED
  THRESHOLD_CHANGED
  APPROVAL_RECORDED
  STATE_TRANSITION
  MONEY_CHANGE
  CUSTOMER_DOC_RELEASED
  STEP_UP_AUTH_REQUIRED
  STEP_UP_AUTH_PASSED
}

// AuditEvent.actorId is intentionally a loose UUID pointer (no FK to
// profiles.id). Industry best practice: audit records are append-only
// and must never fail to write because of referential integrity with a
// parent table. Queries that need actor details JOIN manually.
model AuditEvent {
  id           BigInt         @id @default(autoincrement())
  type         AuditEventType
  actorId      String?        @db.Uuid
  resourceType String?
  resourceId   String?
  metadata     Json           @default("{}")
  occurredAt   DateTime       @default(now())

  @@map("audit_events")
  @@index([actorId, occurredAt])
  @@index([type, occurredAt])
  @@index([resourceType, resourceId, occurredAt])
}
