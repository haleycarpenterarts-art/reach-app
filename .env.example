# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example is the committed template.

# --- Database (Supabase Postgres) ---
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"
# DIRECT_URL is used for migrations (bypasses connection pooling).
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"

# --- Supabase (client + server) ---
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Anthropic (AI: extraction, assistant, scope drafting) ---
ANTHROPIC_API_KEY=""

# --- Resend (transactional + customer-update email) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@example.com"

# --- Sentry (error tracking) ---
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
